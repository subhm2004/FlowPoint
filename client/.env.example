# ─── npm run dev (local) ───
# Best: use /api + Vite proxy (see vite.config.ts). Start backend on port 8000.
# This file is overridden by .env.development when you run `vite` / `npm run dev`.
#
#   VITE_API_BASE_URL=/api
#
# Alternative: call API directly (backend FRONTEND_ORIGIN must include http://localhost:5173):
#   VITE_API_BASE_URL=http://127.0.0.1:8000/api
#
# Proxy target if API is not on 8000:
#   VITE_DEV_PROXY_TARGET=http://127.0.0.1:9000

# ─── Production build (Vercel, etc.) ───
# Set in host dashboard + redeploy. Must be full URL with /api.
# VITE_API_BASE_URL=https://your-service.onrender.com/api

VITE_API_BASE_URL=http://127.0.0.1:8000/api
