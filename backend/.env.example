# Server
PORT=8000
NODE_ENV=development

# API prefix (Express mounts routes under this path)
BASE_PATH=/api

# MongoDB — Atlas or local
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database_name>

# JWT (use a long random secret in production, e.g. openssl rand -base64 32)
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# CORS: allowed browser origin(s). Comma-separated for multiple (no spaces after commas is fine).
# Example: production site + local Vite when the SPA calls this API from localhost:
#   FRONTEND_ORIGIN=https://your-app.vercel.app,http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173
