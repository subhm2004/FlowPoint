# Server
PORT=8000
NODE_ENV=development

# API prefix (Express mounts routes under this path)
BASE_PATH=/api

# MongoDB — Atlas or local
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database_name>

# Session (use a long random string in production)
SESSION_SECRET=session_secret_key_change_me
SESSION_EXPIRES_IN=1d

# Google OAuth — Google Cloud Console → Credentials → OAuth 2.0 Client
# "Authorized redirect URIs" = EXACT same string as GOOGLE_CALLBACK_URL (scheme, host, path, no trailing slash)
# Production example:
#   GOOGLE_CALLBACK_URL=https://your-service.onrender.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8000/api/auth/google/callback

# CORS: exact frontend origin (Vite default is often http://localhost:5173)
FRONTEND_ORIGIN=http://localhost:5173

# Page shown when Google OAuth fails (?status=failure appended by the server)
# Must match client route: /google/oauth/callback
FRONTEND_GOOGLE_CALLBACK_URL=http://localhost:5173/google/oauth/callback
